{
  "compilerOptions": {
    "module": "Node16",
    "rootDir": "src",
    "target": "ES2022",
    "moduleResolution": "Node16",
    "types": [
      "node"
    ],
    "skipLibCheck": true,
    "sourceMap": false,
    "declaration": false,
    "incremental": true,
    "outDir": "dist"
  },
  "exclude": [
    "node_modules",
    "dist"
  ],
  "include": [
    "src"
  ]
}